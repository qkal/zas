{
  "name": "bliss-chat-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/dist/main.js",
  "productName": "Bliss",
  "appId": "com.bliss.chat",
  "build": {
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "build/**/*",
      "electron/dist/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "oxlint",
    "lint:svelte": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint:all": "pnpm lint && pnpm lint:svelte",
    "prepare": "svelte-kit sync",
    "electron:dev": "concurrently \"vite dev\" \"wait-on http://localhost:5173 && electron electron/dist/main.js\"",
    "electron:build": "vite build && tsc -p electron && electron-builder",
    "electron:preview": "pnpm electron:build && electron-builder --win --publish never && start dist-electron/Bliss.exe"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.1.0",
    "@fontsource-variable/geist-mono": "^5.1.0",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.1.0",
    "input-otp": "1.4.2",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@internationalized/date": "^3.10.0",
    "@lucide/svelte": "^0.561.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.8.3",
    "@sveltejs/vite-plugin-svelte": "^5.0.1",
    "@tailwindcss/postcss": "^4.2.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/table-core": "^8.21.3",
    "@types/node": "^22.10.1",
    "bits-ui": "^2.14.4",
    "concurrently": "^9.2.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "electron-store": "^11.0.2",
    "embla-carousel-svelte": "^8.6.0",
    "eslint": "^9.39.4",
    "formsnap": "^2.0.1",
    "layerchart": "2.0.0-next.43",
    "mode-watcher": "^1.1.0",
    "oxlint": "^1.14.0",
    "paneforge": "^1.0.2",
    "postcss": "^8.4",
    "svelte": "^5.2.10",
    "svelte-check": "^4.1.1",
    "svelte-sonner": "^1.0.7",
    "sveltekit-superforms": "^2.28.1",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.0",
    "tslib": "^2.8.1",
    "tw-animate-css": "^1.3.3",
    "typescript": "5.7.3",
    "typescript-eslint": "^8.59.0",
    "vaul-svelte": "1.0.0-next.7",
    "vite": "^6.0.2",
    "wait-on": "^9.0.5"
  }
}
