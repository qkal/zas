{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "style": "off"
  },
  "ignorePatterns": [
    ".svelte-kit",
    "build",
    "dist",
    "node_modules",
    "*.svelte",
    "src/app.d.ts"
  ]
}
